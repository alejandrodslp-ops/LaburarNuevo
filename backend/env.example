# backend/.env.example
# ══════════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO — LABURAR BACKEND
# 
# IMPORTANTE:
# 1. Copiá este archivo y renombralo a .env
# 2. NUNCA subas el archivo .env a GitHub — ya está en .gitignore
# 3. En producción, estas variables se configuran en el hosting
#    (Railway, Render, etc.) — nunca en el código
# ══════════════════════════════════════════════════════════════

# ── Servidor ──
PORT=3000
NODE_ENV=development
APP_VERSION=1.0.0

# ── Base de datos Supabase ──
# Obtener en: supabase.com → tu proyecto → Settings → API
SUPABASE_URL=https://tu-proyecto.supabase.co
SUPABASE_SERVICE_KEY=tu-service-key-aqui

# ── JWT — CAMBIAR EN PRODUCCIÓN ──
# Generar con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_UNA_CLAVE_ALEATORIA_LARGA_Y_SEGURA
JWT_REFRESH_SECRET=CAMBIAR_POR_OTRA_CLAVE_ALEATORIA_DIFERENTE

# ── Salt para hashing adicional ──
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
HASH_SALT=CAMBIAR_POR_UN_SALT_ALEATORIO

# ── MercadoPago ──
# Obtener en: developers.mercadopago.com
MERCADOPAGO_ACCESS_TOKEN=tu-access-token
MERCADOPAGO_PUBLIC_KEY=tu-public-key

# ── URLs ──
FRONTEND_URL=https://laburar.com
API_URL=https://api.laburar.com

# ── Email (para notificaciones) ──
# Usar SendGrid, Resend, o similar
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=tu-api-key
EMAIL_FROM=noreply@laburar.com
